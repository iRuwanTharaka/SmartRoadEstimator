generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────

enum Role {
  ADMIN
  ENGINEER
  CONTRACTOR
}

enum ProjectStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
}

enum Severity {
  LOW
  MEDIUM
  HIGH
}

enum AssignmentStatus {
  ACTIVE
  REVOKED
}

// ─── User ────────────────────────────────────────────────────

model User {
  id                   String    @id @default(uuid())
  name                 String
  email                String    @unique
  phone                String?
  organization         String?
  password             String
  role                 Role      @default(ENGINEER)
  refreshToken         String?
  passwordResetToken   String?
  passwordResetExpiry  DateTime?
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  projects             Project[]           @relation("EngineerProjects")
  assignments          ProjectAssignment[] @relation("ContractorAssignments")
  assignedBy           ProjectAssignment[] @relation("AssignedByUser")
  auditLogs            AuditLog[]

  @@map("users")
}

// ─── Project ─────────────────────────────────────────────────

model Project {
  id          String        @id @default(uuid())
  name        String
  location    String
  roadLength  Float?        @map("road_length")
  roadWidth   Float?        @map("road_width")
  surfaceType String?       @map("surface_type")
  contractor  String?
  notes       String?
  status      ProjectStatus @default(DRAFT)
  engineerId  String        @map("engineer_id")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  engineer    User          @relation("EngineerProjects", fields: [engineerId], references: [id])
  images      Image[]
  detections  Detection[]
  estimations Estimation[]
  assignments ProjectAssignment[]

  @@map("projects")
}

// ─── Project Assignment ──────────────────────────────────────

model ProjectAssignment {
  id            String           @id @default(uuid())
  projectId     String           @map("project_id")
  contractorId  String           @map("contractor_id")
  assignedById  String           @map("assigned_by_id")
  status        AssignmentStatus @default(ACTIVE)
  assignedAt    DateTime         @default(now()) @map("assigned_at")

  project       Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contractor    User    @relation("ContractorAssignments", fields: [contractorId], references: [id])
  assignedBy    User    @relation("AssignedByUser", fields: [assignedById], references: [id])

  @@unique([projectId, contractorId])
  @@map("project_assignments")
}

// ─── Image ───────────────────────────────────────────────────

model Image {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  imageUrl    String   @map("image_url")
  publicId    String?  @map("public_id")
  latitude    Float?
  longitude   Float?
  capturedAt  DateTime? @map("captured_at")
  uploadedAt  DateTime @default(now()) @map("uploaded_at")

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("images")
}

// ─── Detection ───────────────────────────────────────────────

model Detection {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  x         Float
  y         Float
  width     Float
  height    Float
  area      Float    @default(0)
  severity  Severity @default(MEDIUM)
  label     String?
  createdAt DateTime @default(now()) @map("created_at")

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("detections")
}

// ─── Rate Tables ─────────────────────────────────────────────

model RateMaterial {
  id          String   @id @default(uuid())
  name        String
  unit        String
  costPerUnit Float    @map("cost_per_unit")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("rates_material")
}

model RateLabor {
  id          String   @id @default(uuid())
  name        String
  unit        String
  costPerHour Float    @map("cost_per_hour")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("rates_labor")
}

model RateEquipment {
  id          String   @id @default(uuid())
  name        String
  unit        String
  costPerUse  Float    @map("cost_per_use")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("rates_equipment")
}

// ─── Estimation ──────────────────────────────────────────────

model Estimation {
  id            String   @id @default(uuid())
  projectId     String   @map("project_id")
  materialCost  Float    @map("material_cost")
  laborCost     Float    @map("labor_cost")
  equipmentCost Float    @map("equipment_cost")
  totalCost     Float    @map("total_cost")
  totalArea     Float    @map("total_area")
  breakdown     Json?
  createdAt     DateTime @default(now()) @map("created_at")

  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("estimations")
}

// ─── Audit Log ───────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  metadata   Json?
  timestamp  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}
